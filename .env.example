# === Скопируй в .env и заполни. .env в git НЕ попадает (см. .gitignore) ===

# --- Telegram ---
# Токен бота от @BotFather. НУЖНО ОТ ТЕБЯ (см. список в конце сессии).
TELEGRAM_BOT_TOKEN=

# Telegram ID преподавателей, которым разрешён вход (через запятую).
# Пусто = в режиме прототипа преподавателем становится любой, кто нажал /start.
ALLOWED_TEACHER_IDS=

# --- База данных ---
# Прототип: локальный SQLite. Боевой контур: postgresql+psycopg://user:pass@host:6432/vedomost
DATABASE_URL=sqlite:///vedomost.db

# --- Yandex Cloud ---
YC_FOLDER_ID=b1gvtru3guuc1oipcs4p
YC_SA_KEY_FILE=C:/Users/Владимир/Downloads/Telegram Desktop/leonov-deployer-key.json

# --- SpeechKit (голосовой ввод) ---
# Роль ai.speechRecognition.user на сервисном аккаунте (проверим при интеграции голоса).
SPEECHKIT_ENABLED=false

# --- Yandex AI Studio (LLM для разбора текста и ПУД) ---
# Модель из плана: Qwen3-235B / или foundation model YandexGPT. Уточним при интеграции.
AI_STUDIO_ENABLED=false
AI_STUDIO_MODEL=
